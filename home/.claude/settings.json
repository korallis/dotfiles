{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "gh-axi",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "chrome-devtools-axi",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "lavish-axi",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/leebarry/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); if [ -n \"$used\" ]; then printf \"%s | ctx: %.0f%% used\" \"$model\" \"$used\"; else printf \"%s\" \"$model\"; fi",
    "type": "command"
  },
  "theme": "dark-ansi"
}